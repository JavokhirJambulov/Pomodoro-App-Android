<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Pomodoro" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/button_color</item>
        <item name="colorPrimaryVariant">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/purple_200</item>
        <item name="colorSecondaryVariant">@color/button_color</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="statusBarForeground" >?attr/colorPrimaryVariant</item>
        <item name="statusBarBackground">?attr/colorOnPrimary</item>
        <item name="android:buttonStyle">@style/AppTheme.Button</item>
        <item name="buttonStyle">@style/AppTheme.Button</item>
        <item name="alertDialogTheme">@style/SmallDialogTheme</item>
    </style>

    <style name="SmallDialogTheme" parent="@style/Theme.AppCompat.DayNight.Dialog.Alert">
        <item name="dialogCornerRadius">20dp</item>
        <item name="android:buttonStyle">@style/AppTheme.Button</item>
        <item name="buttonStyle">@style/AppTheme.Button</item>
    </style>

    <style name="AppTheme.Button" parent="Widget.AppCompat.Button">
        <item name="textAllCaps">false</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textAppearance">?android:attr/textAppearanceSmallInverse</item>
    </style>

</resources>
